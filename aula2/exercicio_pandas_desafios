import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np

plt.rcParams.update({'figure.figsize': (10,5), 'axes.spines.top': False, 'axes.spines.right': False})

# ==============================================================================
# 1. dataset
# ==============================================================================

np.random.seed(42)
produtos = {
    "Dom Casmurro": ("Literatura", 35.90), "O Pequeno Príncipe": ("Infantil", 29.90),
    "Sapiens": ("Ciências", 54.90), "Python para Dados": ("Tecnologia", 89.90),
    "Clean Code": ("Tecnologia", 95.00), "Harry Potter Vol.1": ("Fantasia", 49.90),
    "Atomic Habits": ("Autoajuda", 44.90), "A Arte da Guerra": ("Filosofia", 32.00),
    "Cosmos": ("Ciências", 62.50), "Cem Anos de Solidão": ("Literatura", 39.90)
}
vendedores = ["Ana Lima", "Carlos Mendes", "Bruno Costa", "Fernanda Rocha"]
regioes = ["Sudeste", "Sul", "Nordeste", "Norte", "Centro-Oeste"]
datas = pd.date_range("2024-01-01", "2024-06-30", periods=50)
nomes_prod = np.random.choice(list(produtos.keys()), 50)

df = pd.DataFrame({
    "id_venda": range(1,51), "data": datas.strftime("%Y-%m-%d"), "produto": nomes_prod,
    "categoria": [produtos[p][0] for p in nomes_prod],
    "quantidade": np.random.randint(1,6,50), "preco_unit": [produtos[p][1] for p in nomes_prod],
    "vendedor": np.random.choice(vendedores,50), "regiao": np.random.choice(regioes,50)
})
df["total_venda"] = df["quantidade"] * df["preco_unit"]
df.to_csv("vendas_livraria.csv", index=False)

# ==============================================================================
# 2. exploração (eda)
# ==============================================================================

print("shape:", df.shape)
print(df.dtypes)
print("nulos:\n", df.isnull().sum())
print(df[["quantidade","preco_unit","total_venda"]].describe().round(2))

# ==============================================================================
# 3. análise de vendas
# ==============================================================================

total = df["total_venda"].sum()
print(f"Faturamento Total: R$ {total:,.2f}")

cat_fat = df.groupby("categoria")["total_venda"].sum().sort_values(ascending=False)
print("\nfaturamento por categoria:\n", cat_fat.apply(lambda x: f"R$ {x:,.2f}"))

vend_rank = df.groupby("vendedor")["total_venda"].sum().sort_values(ascending=False)
print("\nranking vendedores:\n", vend_rank.apply(lambda x: f"R$ {x:,.2f}"))

top_prod = df.groupby("produto")["quantidade"].sum().sort_values(ascending=False).head(3)
print("\ntop 3 produtos (qtd):\n", top_prod)

reg_media = df.groupby("regiao")["total_venda"].mean().sort_values(ascending=False).round(2)
print("\nticket médio por região:\n", reg_media.apply(lambda x: f"R$ {x:,.2f}"))

# ==============================================================================
# 4. visualizer
# ==============================================================================

fig, axes = plt.subplots(1,3, figsize=(16,5))
fig.suptitle("Dashboard Livraria 2024", fontsize=14, fontweight="bold")

cores = ["#e84b1a"] + ["#c8bfaa"]*(len(cat_fat)-1)
axes[0].barh(cat_fat.index, cat_fat.values, color=cores)
axes[0].set_title("faturamento por categoria")
axes[0].xaxis.set_major_formatter(mticker.FuncFormatter(lambda x,_: f"R${x/1000:.0f}k"))

cores_vend = ["#1a6ee8","#4a90e8","#8ab8f0","#c8d8f0"][:len(vend_rank)]
axes[1].bar(vend_rank.index, vend_rank.values, color=cores_vend)
axes[1].set_title("ranking vendedores")
axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda y,_: f"R${y/1000:.0f}k"))
axes[1].tick_params(axis="x", rotation=15)

reg_total = df.groupby("regiao")["total_venda"].sum()
axes[2].pie(reg_total, labels=reg_total.index, autopct="%1.1f%%", startangle=90,
            colors=["#e84b1a","#1a6ee8","#c9a84c","#28a745","#6f42c1"])
axes[2].set_title("participação por região")

plt.tight_layout()
plt.show()

# ==============================================================================
# desafio n1: evolução mensal
# (obs: isso aq pra baixo faz parte da aba / tópicos "desafios para ir além")
# ==============================================================================

df["mes"] = pd.to_datetime(df["data"]).dt.month
fat_mensal = df.groupby("mes")["total_venda"].sum()
plt.figure()
plt.plot(fat_mensal.index, fat_mensal.values, marker="o", color="#e84b1a")
plt.title("faturamento mensal")
plt.xlabel("mês")
plt.ylabel("R$")
plt.xticks(range(1,7), ["jan","fev","mar","abr","mai","jun"])
plt.grid(alpha=0.3)
plt.show()

# ==============================================================================
# desafio n2: tendência com média móvel
# ==============================================================================

vendas_diarias = df.groupby("data")["total_venda"].sum().reset_index()
vendas_diarias["data"] = pd.to_datetime(vendas_diarias["data"])
vendas_diarias["mm7"] = vendas_diarias["total_venda"].rolling(7, min_periods=1).mean()
plt.figure(figsize=(12,5))
plt.plot(vendas_diarias["data"], vendas_diarias["total_venda"], alpha=0.5, color="gray", label="diário")
plt.plot(vendas_diarias["data"], vendas_diarias["mm7"], color="#e84b1a", linewidth=2, label="média móvel 7d")
plt.title("tendência de vendas")
plt.legend()
plt.xticks(rotation=45)
plt.show()

# ==============================================================================
# desafio n3: vendedor com maior ticket médio
# ==============================================================================
ticket_medio = df.groupby("vendedor")["total_venda"].mean().sort_values(ascending=False).round(2)
print("\nticket médio por vendedor:\n", ticket_medio.apply(lambda x: f"R$ {x:,.2f}"))

# ==============================================================================
# desafio n4: vendas de alto valor (>200)
# ==============================================================================
alto_valor = df[df["total_venda"] > 200]
print(f"\nVendas >200: {len(alto_valor)} registros, R$ {alto_valor['total_venda'].sum():,.2f}")
cat_alto = alto_valor.groupby("categoria")["total_venda"].sum().sort_values(ascending=False)
print("Categorias:\n", cat_alto.apply(lambda x: f"R$ {x:,.2f}"))

# ==============================================================================
# desafio n5: inserir e tratar nulos
# ==============================================================================
df_nulos = df.copy()
indices = np.random.choice(df_nulos.index, 5, replace=False)
for i, idx in enumerate(indices):
    col = ["quantidade","preco_unit","vendedor","regiao","total_venda"][i%5]
    df_nulos.loc[idx, col] = np.nan

print("\nnulos antes:\n", df_nulos.isnull().sum()[df_nulos.isnull().sum()>0])

df_nulos["quantidade"] = df_nulos["quantidade"].fillna(df_nulos["quantidade"].mean())
df_nulos["preco_unit"] = df_nulos["preco_unit"].fillna(df_nulos["preco_unit"].mean())
df_nulos["vendedor"] = df_nulos["vendedor"].fillna(df_nulos["vendedor"].mode()[0])
df_nulos["regiao"] = df_nulos["regiao"].fillna(df_nulos["regiao"].mode()[0])
df_nulos["total_venda"] = df_nulos.apply(lambda r: r["quantidade"]*r["preco_unit"] if pd.isna(r["total_venda"]) else r["total_venda"], axis=1)

print("nulos depois:\n", df_nulos.isnull().sum()[df_nulos.isnull().sum()>0])
print("todos os nulos tratados.")
